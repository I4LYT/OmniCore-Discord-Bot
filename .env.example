# Rename this file to .env and paste your real Discord bot token below.
# Never share your bot token publicly.
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Ollama settings. Use http://127.0.0.1:11434 when Ollama runs on the same
# machine as the bot, or http://YOUR_HOME_SERVER_IP:11434 for another machine.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Leave blank to use the first model returned by Ollama, or set one from
# `ollama list`, such as llama3.2:latest.
OLLAMA_MODEL=

# Optional: tune how the bot behaves when answering mentions.
OLLAMA_SYSTEM_PROMPT=You are OmniCore, a helpful Discord bot. Keep replies concise unless detail is requested.
OLLAMA_TIMEOUT_SECONDS=120
